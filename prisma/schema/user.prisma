enum USER_ROLE {
    ADMIN
    USER
    MODERATOR
}

model User {
    id String @id @default(cuid())
    userName String @map("user_name")
    password String
    
    cityId String @default("cmmjcycy600013b6svl5n4s62") @map("city_id")
    city City @relation(references: [id], fields: [cityId])

    email String @unique
    imageUrl String @map("image_url") @default("/static/default/default-user.svg")
    role USER_ROLE @default(USER) 

    @@index([role])
    @@index([email])
    @@index([cityId])
}